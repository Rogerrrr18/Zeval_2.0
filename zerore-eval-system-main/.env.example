# Zeval LLM Judge. Any OpenAI-compatible gateway can be used here.
ZEVAL_JUDGE_API_KEY=YOUR_API_KEY_HERE
# Optional: intent-pointer dynamic eval pilot (frontend may persist into server env). Falls back to ZEVAL_JUDGE_API_KEY when unset.
ZEVAL_INTENT_EXPERIMENT_API_KEY=
ZEVAL_JUDGE_BASE_URL=https://api.siliconflow.cn/v1
ZEVAL_JUDGE_MODEL=Qwen/Qwen3.5-27B
ZEVAL_JUDGE_ENABLE_THINKING=false

# 在线评测默认回复通道（与 mock-customer-api 的 POST /reply 对齐，可写完整 URL 或基址）
SILICONFLOW_CUSTOMER_API_URL=http://127.0.0.1:4200

# Tenancy. Zeval data is isolated by Organization -> Project. workspaceId is a legacy alias for projectId.
ZEVAL_DEFAULT_ORGANIZATION_ID=default-org

# Database adapter. Keep local-json for local dev; use postgres for Supabase/Postgres.
ZEVAL_DATABASE_ADAPTER=local-json
# DATABASE_URL=postgresql://postgres:YOUR_DB_PASSWORD@db.rukjxsykowetriaxifon.supabase.co:5432/postgres
ZEVAL_POSTGRES_SSL=auto
ZEVAL_POSTGRES_POOL_MAX=5
DATASET_STORE_PROVIDER=filesystem
WORKBENCH_BASELINE_STORE_PROVIDER=filesystem

# Supabase project metadata. The publishable key is not enough for server-side Postgres writes.
NEXT_PUBLIC_SUPABASE_URL=https://rukjxsykowetriaxifon.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SUPABASE_PUBLISHABLE_KEY
SUPABASE_PROJECT_REF=rukjxsykowetriaxifon
