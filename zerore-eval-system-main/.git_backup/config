[core]
	repositoryformatversion = 0
	filemode = true
	bare = false
	logallrefupdates = true
	ignorecase = true
	precomposeunicode = true
[remote "origin"]
	url = https://github.com/Designer-Awei/zerore-eval-system.git
	fetch = +refs/heads/*:refs/remotes/origin/*
[branch "Zeval"]
	remote = origin
	merge = refs/heads/Zeval
	vscode-merge-base = origin/main
