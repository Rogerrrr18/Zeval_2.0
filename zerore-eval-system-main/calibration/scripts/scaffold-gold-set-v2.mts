import { access, mkdir, writeFile } from "node:fs/promises";
import path from "node:path";
import * as calibrationJsonl from "../../src/calibration/jsonl.ts";
import * as calibrationPaths from "../../src/calibration/paths.ts";
import * as goldSetScaffold from "../../src/calibration/goldSetScaffold.ts";
import type {
  GoldSetAnnotationTaskRecord,
  GoldSetCaseRecord,
  GoldSetLabelDraftRecord,
} from "../../src/calibration/types.ts";

const calibrationJsonlApi = resolveInteropModule(calibrationJsonl);
const calibrationPathsApi = resolveInteropModule(calibrationPaths);
const goldSetScaffoldApi = resolveInteropModule(goldSetScaffold);

void main().catch((error) => {
  console.error("[gold:v2:scaffold] failed", error);
  process.exitCode = 1;
});

/**
 * Generate assignable annotation tasks and blank draft files for a gold set.
 */
async function main(): Promise<void> {
  const args = process.argv.slice(2);
  const version = getFlagValue(args, "--version") ?? "v2";
  const sourceCasesPath = path.resolve(
    getFlagValue(args, "--from") ?? calibrationPathsApi.resolveCalibrationPath("gold-sets", "v1", "cases.jsonl"),
  );
  const outputDirectory = path.resolve(
    getFlagValue(args, "--out") ?? calibrationPathsApi.resolveCalibrationPath("gold-sets", version),
  );
  const force = args.includes("--force");
  const assignees = parseCsvFlag(args, "--assignees");
  const reviewers = parseCsvFlag(args, "--reviewers");
  const createdAt = new Date().toISOString();

  await assertWritableScaffoldTarget(outputDirectory, force);

  const cases = await calibrationJsonlApi.readJsonlFile<GoldSetCaseRecord>(sourceCasesPath);
  const tasks = goldSetScaffoldApi.buildGoldSetAnnotationTasks(cases, {
    goldSetVersion: version,
    sourceCasesPath: toRepoRelativePath(sourceCasesPath),
    createdAt,
    assignees,
    reviewers,
    defaultPriority: "P1",
  });
  const drafts = tasks.map((task) => goldSetScaffoldApi.buildGoldSetLabelDraftTemplate(task));

  await mkdir(path.join(outputDirectory, "label-drafts"), { recursive: true });
  await calibrationJsonlApi.writeJsonlFile(path.join(outputDirectory, "cases.jsonl"), cases);
  await calibrationJsonlApi.writeJsonlFile(path.join(outputDirectory, "annotation-tasks.jsonl"), tasks);
  await Promise.all(
    drafts.map((draft) =>
      writeJsonFile(path.join(outputDirectory, "label-drafts", `${draft.taskId}.json`), draft),
    ),
  );
  await writeFile(path.join(outputDirectory, "README.md"), renderReadme(version, cases.length, tasks), "utf8");
  await writeFile(path.join(outputDirectory, "label-drafts", "README.md"), renderDraftReadme(version), "utf8");

  console.info(
    `[gold:v2:scaffold] version=${version} cases=${cases.length} tasks=${tasks.length} output=${outputDirectory}`,
  );
}

/**
 * Refuse accidental overwrite unless `--force` is explicit.
 *
 * @param outputDirectory Target gold-set directory.
 * @param force Whether overwrites are allowed.
 */
async function assertWritableScaffoldTarget(outputDirectory: string, force: boolean): Promise<void> {
  if (force) {
    return;
  }

  try {
    await access(path.join(outputDirectory, "annotation-tasks.jsonl"));
  } catch {
    return;
  }

  throw new Error(`已存在 annotation-tasks.jsonl：${outputDirectory}。如需覆盖请加 --force。`);
}

/**
 * Write one stable JSON file.
 *
 * @param filePath Target file path.
 * @param payload JSON payload.
 */
async function writeJsonFile(filePath: string, payload: GoldSetLabelDraftRecord): Promise<void> {
  await mkdir(path.dirname(filePath), { recursive: true });
  await writeFile(filePath, `${JSON.stringify(payload, null, 2)}\n`, "utf8");
}

/**
 * Render version README.
 *
 * @param version Gold-set version.
 * @param caseCount Number of source cases.
 * @param tasks Annotation tasks.
 * @returns Markdown content.
 */
function renderReadme(version: string, caseCount: number, tasks: GoldSetAnnotationTaskRecord[]): string {
  const assignedCount = tasks.filter((task) => Boolean(task.assignee)).length;
  const reviewerCount = tasks.filter((task) => Boolean(task.reviewer)).length;
  return `# Gold Set ${version.toUpperCase()}

This directory is generated by \`npm run gold:v2:scaffold\`.

## Files

- \`cases.jsonl\`: case records used by judge calibration.
- \`annotation-tasks.jsonl\`: assignable task index for labelers and reviewers.
- \`label-drafts/*.json\`: one editable draft per task.
- \`labels.jsonl\`: generated only after approved drafts are imported.
- \`import-report.md\`: generated import gate report.

## Current Scope

- Cases: ${caseCount}
- Assigned Tasks: ${assignedCount}
- Tasks With Reviewer: ${reviewerCount}

## Workflow

1. Assign owners in \`annotation-tasks.jsonl\` or regenerate with \`--assignees\` / \`--reviewers\`.
2. Labelers fill their draft files under \`label-drafts/\`.
3. Reviewers set \`reviewStatus\` to \`approved\` only after evidence and scores are checked.
4. Run \`npm run gold:v2:import\` to produce \`labels.jsonl\`.
5. Run \`npm run calibration:judge -- --cases calibration/gold-sets/${version}/cases.jsonl\` and then agreement against the imported labels.
`;
}

/**
 * Render label-draft instructions.
 *
 * @param version Gold-set version.
 * @returns Markdown content.
 */
function renderDraftReadme(version: string): string {
  return `# ${version} Label Drafts

Each JSON file is intentionally editable by a human labeler.

Import requirements:
- \`reviewStatus\` must be \`approved\`.
- \`labeler\`, \`reviewer\`, and \`reviewedAt\` must be filled.
- Every required dimension needs a 1-5 score and non-empty evidence.
- \`goalCompletion.status\` must be \`achieved\`, \`partial\`, \`failed\`, or \`unclear\`.
- \`recoveryTrace.status\` must be \`none\`, \`completed\`, or \`failed\`.
- \`recoveryTrace.status=none\` requires \`qualityScore=0\`.
`;
}

/**
 * Read one optional CLI flag value.
 *
 * @param args Raw CLI args.
 * @param flag Flag name.
 * @returns Flag value when present.
 */
function getFlagValue(args: string[], flag: string): string | undefined {
  const index = args.indexOf(flag);
  if (index < 0) {
    return undefined;
  }
  return args[index + 1];
}

/**
 * Parse a comma-separated roster flag.
 *
 * @param args Raw CLI args.
 * @param flag Flag name.
 * @returns Cleaned values.
 */
function parseCsvFlag(args: string[], flag: string): string[] {
  return (getFlagValue(args, flag) ?? "")
    .split(",")
    .map((item) => item.trim())
    .filter(Boolean);
}

/**
 * Keep generated task metadata portable across machines.
 *
 * @param filePath Absolute path.
 * @returns Repo-relative path when possible.
 */
function toRepoRelativePath(filePath: string): string {
  const relativePath = path.relative(process.cwd(), filePath);
  if (!relativePath || relativePath.startsWith("..")) {
    return filePath;
  }
  return relativePath;
}

/**
 * Normalize tsx loader interop.
 *
 * @param module Imported module namespace.
 * @returns Stable module surface.
 */
function resolveInteropModule<T>(module: T): T {
  return ((module as T & { default?: T }).default ?? module) as T;
}
